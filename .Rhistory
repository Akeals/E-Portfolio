#load our packages
library(lidR)
library(terra)
library(tidyverse)
#load RGB image, explore the structure and plot it
rgb_mkrf <- rast('Data/Aerial_Photo/MKRF_Aerial_Photo.tif')
str(rgb_mkrf)
plotRGB(rgb_mkrf)
#Create LAScatalog object from MKRF las tiles
cat_mkrf <- readLAScatalog("Data/LAS")
#Inspect the LAScatalog with check and summary functions
las_check(cat_mkrf)
summary(cat_mkrf)
#plot the LAScatalog
plot(cat_mkrf)
#Examine single .las tile to determine duplication
tile_1_mkrf <- readLAS("Data/LAS/MKRF_Tile1.las")
las_check(tile_1_mkrf)
#Set the output directory for the filtered .las data
opt_output_files(cat_mkrf) <- paste("Data", "/Filtered/filtered_mkrf_{ID}", sep = "")
cat_mkrf <- filter_duplicates(cat_mkrf) #remove duplicate points and speed up processing
cat_mkrf <- filter_duplicates(cat_mkrf) #remove duplicate points and speed up processing
#confirm that duplicates were removed for Tile 1
filtered_t1_mkrf <- readLAS("Data/Filtered/filtered_mkrf_1.las")
las_check(filtered_t1_mkrf)
#read filtered .las into LAScatalog, get a summary and plot it
filtered_cat_mkrf <- readLAScatalog("Data/Filtered")
summary(filtered_cat_mkrf)
plot(filtered_cat_mkrf)
#Create DEM with tin algorithm
dem_allLAS_mkrf <- rasterize_terrain(filtered_cat_mkrf, 2, tin())
#Create color palette
col_1 <- height.colors(50)
#Plot DEM using color palette
plot(dem_allLAS_mkrf, col = col_1) #plot in 2D
#define LAScatalog engine options
opt_output_files(filtered_cat_mkrf) <- paste("Data", "/Normalized/norm_mkrf_{ID}", sep = "")
#normalize all tiles in cat_mkrf with the DEM
norm_tiles_mkrf <- normalize_height(filtered_cat_mkrf, dem_allLAS_mkrf) #check your folder when complete
#normalize all tiles in cat_mkrf with the DEM
norm_tiles_mkrf <- normalize_height(filtered_cat_mkrf, dem_allLAS_mkrf) #check your folder when complete
