knitr::opts_chunk$set(echo = TRUE)
#load our packages
library(lidR)
#load our packages
library(lidR)
library(terra)
library(tidyverse)
#load RGB image, explore the structure and plot it
rgb_afrf <- rast('Data/Aerial_Photo/AFRF_Aerial_Photo.tif')
str(rgb_afrf)
plotRGB(rgb_afrf)
#Create LAScatalog object from AFRF las tiles
cat_afrf <- readLAScatalog("Data/LAS")
#Create LAScatalog object from AFRF las tiles
cat_afrf <- readLAScatalog("Data/LAS")
#Inspect the LAScatalog with check and summary functions
las_check(cat_afrf)
summary(cat_afrf)
#Set the output directory for the filtered .las data
opt_output_files(cat_afrf) <- paste("Data", "/Filtered/filtered_afrf_{ID}", sep = "")
#remove duplicate points and speed up processing
cat_afrf <- filter_duplicates(cat_afrf)
#remove duplicate points and speed up processing
cat_afrf <- filter_duplicates(cat_afrf)
#read filtered .las into LAScatalog, get a summary and plot it
filtered_cat_afrf <- readLAScatalog("Data/Filtered")
summary(filtered_cat_afrf)
plot(filtered_cat_afrf)
#Create DEM with tin algorithm
dem_afrf <- rasterize_terrain(filtered_cat_afrf, 2, tin())
#Create color palette
colour_pal <- height.colors(50)
#Plot DEM using color palette
plot(dem_afrf, col = colour_pal)
#define LAScatalog engine options
opt_output_files(filtered_cat_afrf) <- paste("Data", "/Normalized LAS/norm_afrf_{ID}", sep = "")
#normalize all tiles in cat_afrf with the DEM
norm_tiles_afrf <- normalize_height(filtered_cat_afrf, dem_afrf)
#normalize all tiles in cat_afrf with the DEM
norm_tiles_afrf <- normalize_height(filtered_cat_afrf, dem_afrf)
#check to see if the normalization worked
norm_afrf_1 <- readLAS("Data/Normalized LAS/norm_afrf_1.las")
plot(norm_afrf_1)
#read normalized las into catalog to continue processing
norm_cat_afrf <- readLAScatalog("Data/Normalized LAS")
#add LAScatalog enginge option to filter undersired data points
opt_filter(norm_cat_afrf) <- '-drop_z_below 0 -drop_z_above 55'
#ensure the entire study area was processed
plot(norm_cat_afrf)
summary(norm_cat_afrf)
#Create CHM for all normalized AFRF Tiles using p2r algorithm
chm_afrf <- rasterize_canopy(norm_cat_afrf, 2, p2r())
#plot in 2D
plot(chm_afrf, col = colour_pal)
#read 'Plot_Table.csv'
plot_table <- read.csv("Data/Plots/Plot_Table.csv")
#define plot radius
radius <- 30
#for loop to extract multiple plots
for(i in 1:nrow(plot_table)){
plot_cent <- c(plot_table$X[i], plot_table$Y[i]) #extract plot center
plot_las <- clip_circle(norm_cat_afrf, plot_cent[1], plot_cent[2], radius) #clip plot from norm_cat_las
output_file <- paste("Data/Plots/AFRF_Plot_", i, ".las", sep = "") #output directory as string
writeLAS(assign(paste("AFRF_Plot_", i, sep = ""), plot_las), output_file)
}
#Calculate metrics for all plots
#create empty dataframe
afrf_plot_metrics <- data.frame()
#For loop to calculate metrics for all plots
for(i in 1:nrow(plot_table)){
plot <- readLAS(paste("Data/Plots/afrf_Plot_", i, ".las", sep= ""), filter = "-keep_first -drop_z_below 2")
metrics <- cloud_metrics(plot, .stdmetrics) #compute standard metrics
afrf_plot_metrics <- rbind(afrf_plot_metrics, metrics) #add the new 'metrics' to 'afrf_cloud_metrics'
}
#Export afrf_plot_metrics as .csv in Plots folder
write_csv(afrf_plot_metrics, "Data/Plots/afrf_plot_metrics.csv")
#join lidar metrics and forest attributes into 1 table
#Add column to "afrf_plot_metrics' called Plot_ID (join key)
afrf_plot_metrics$Plot_ID = 1:38
#Join 'Plot_Table' and 'afrf_Plot_Metrics' into 'data_table'
data_table <- plot_table %>%
full_join(afrf_plot_metrics)
#list all the column names in our data_table (This is a combination of our two tables)
colnames(data_table)
#plot the relationship between lidar metrics and Total_AGB
plot(Total_AGB ~ zq50, data = data_table)
#Fit a linear model between a single lidar metric and volume
model = lm(Total_AGB ~ zq50, data = data_table)
#Display a summary of the model
summary(model)
#Fit a linear model using multiple predictors (separating the predictors by '+' sign)
model = lm(Total_AGB ~ zq50 + zq90, data = data_table)
#Display a summary of the model
summary(model)
#plot the relationship between lidar metrics and Dominant_Height
plot(Dominant_Height ~ zq50, data = data_table)
#Fit a linear model between a single lidar metric and volume
model = lm(Dominant_Height ~ zq50, data = data_table)
#Display a summary of the model
summary(model)
#Fit a linear model using multiple predictors (separating the predictors by '+' sign)
model = lm(Dominant_Height ~ zq50 + zq90, data = data_table)
#Display a summary of the model
summary(model)
#list all the column names in our data_table (This is a combination of our two tables)
colnames(data_table)
#plot the relationship between lidar metrics and Total_AGB
plot(Total_AGB ~ zq50, data = data_table)
#Fit a linear model between a single lidar metric and volume
model = lm(Total_AGB ~ zq50, data = data_table)
#Display a summary of the model
summary(model)
#Fit a linear model using multiple predictors (separating the predictors by '+' sign)
model = lm(Total_AGB ~ zq50 + zq90, data = data_table)
#Display a summary of the model
summary(model)
#plot the relationship between lidar metrics and Dominant_Height
plot(Dominant_Height ~ zq50, data = data_table)
#Fit a linear model between a single lidar metric and volume
model = lm(Dominant_Height ~ zq50, data = data_table)
#Display a summary of the model
summary(model)
#Fit a linear model using multiple predictors (separating the predictors by '+' sign)
model = lm(Dominant_Height ~ zq50 + zq90, data = data_table)
#Display a summary of the model
summary(model)
#Explore the correlation between our lidar metrics
#Create a matrix of scatterplots between different height percentiles
pairs(~ zq10 + zq25 + zq50 + zq75 + zq90, data = data_table)
#Create a matrix of scatterplots between less correlated variables
pairs(~ zq75 + pzabove2 + zentropy + zskew + zsd,data = data_table)
#We start with no variables in our model
model1 = lm(Total_AGB ~ 1, data = data_table)
#Now, we add each selected variable to our model one by one, to see which variable is the most significant
add1(model1,~  zq90 + pzabove2 + zentropy + zskew, test = 'F')
# zq90 was the most significant (lowest Pr(>F)), so we add it to our model
model1 = lm(Total_AGB ~ zq90, data = data_table)
#Add each remaining variable to the new model
add1(model1,~  zq90 + pzabove2 + zentropy + zskew, test = 'F')
# zentropy was the most significant (lowest Pr(>F)), so we add it to our model
model1 = lm(Total_AGB ~ zq90 + zentropy, data = data_table)
#Add each remaining variable to the new model
add1(model1,~  zq90 + pzabove2 + zentropy + zskew, test = 'F')
#Get the summary of the final model
summary(model1)
#We start with no variables in our model
model2 = lm(Dominant_Height ~ 1, data = data_table)
#Add each selected variable to our model one by one, to see which variable is the most significant
add1(model2,~  zq75 + pzabove2 + zentropy + zsd, test = 'F')
# zq75 was the most significant (lowest Pr(>F)), so we add it to our model
model2 = lm(Dominant_Height ~ zq75, data = data_table)
#Add each remaining variable to the new model
add1(model2,~  zq75 + pzabove2 + zentropy + zsd, test = 'F')
# pzabove2 was the most significant (lowest Pr(>F)), so we add it to our model
model2 = lm(Dominant_Height ~ zq75 + pzabove2, data = data_table)
#Add each remaining variable to the new model
add1(model2,~  zq75 + pzabove2 + zentropy + zsd, test = 'F')
#Get the summary of the final model
summary(model2)
#Model 1 - Plot our predicted ABG against our measured ABG
plot(Total_AGB ~ model1$fitted,data = data_table,xlab = 'Predicted',ylab = 'Measured')
abline(0,1)
#Model 2- Plot our predicted DH against our measured DH
plot(Dominant_Height ~ model2$fitted,data = data_table,xlab = 'Predicted',ylab = 'Measured')
#Total ABG across AFRF
# Compute grid metrics for all normalized LAS tiles
pixel_metrics_all <- pixel_metrics(norm_cat_afrf, .stdmetrics_z, 10)
#Total ABG across AFRF
# Compute grid metrics for all normalized LAS tiles
pixel_metrics_all <- pixel_metrics(norm_cat_afrf, .stdmetrics_z, 10)
# 2. Extract predictor rasters
zq90_raster <- terra::subset(pixel_metrics_all, "zq90")
zentropy_raster <- terra::subset(pixel_metrics_all, "zentropy")
# 3. Stack predictors
predictors_stack <- c(zq90_raster, zentropy_raster)
names(predictors_stack) <- c("zq90","zentropy")
# 4. Create function using model1 coefficients
f_total_agb <- function(x){
609811 + 16293*x[1] - 975484*x[2]
}
# 5. Apply function to raster
total_agb_raster <- terra::app(predictors_stack, f_total_agb)
# 5. Apply function to raster
total_agb_raster <- terra::app(predictors_stack, f_total_agb)
plot(total_agb_raster, main="Predicted Total AGB")
#Total DH across AFRF
# Extract predictor rasters
zq75_raster <- terra::subset(pixel_metrics_all, "zq75")
pzabove2_raster <- terra::subset(pixel_metrics_all, "pzabove2")
# Stack
predictors_stack2 <- c(zq75_raster, pzabove2_raster)
names(predictors_stack2) <- c("zq75","pzabove2")
# Function
f_dh <- function(x){
3232.677 + 0.80641*x[1] - 32.23176*x[2]
}
# Apply
dominant_height_raster <- terra::app(predictors_stack2, f_dh)
# Apply
dominant_height_raster <- terra::app(predictors_stack2, f_dh)
plot(dominant_height_raster, main="Predicted Dominant Height")
