# Convert confusion matrix to proportions by reference class
conf_prop <- prop.table(conf_matrix, 2)
# Calculate UA and PA
PA <- diag(conf_prop)  # column-wise
UA <- diag(conf_prop) / rowSums(conf_prop) * ncol(conf_prop) # adjusted to fit in plot
# Add UA as a new column and PA as a new row
conf_aug <- as.data.frame(conf_prop)
conf_aug$UA <- UA
# Melt for ggplot
conf_long <- melt(conf_aug, id.vars = "Predicted")
colnames(conf_long) <- c("Predicted", "Reference", "Proportion")
# Melt for ggplot
conf_long <- melt(conf_aug, id.vars = "Predicted")
View(conf_aug)
# 1️⃣ Convert confusion matrix to proportions by reference class
conf_prop <- prop.table(conf_matrix, 2)  # values 0-1
conf_df <- as.data.frame(conf_prop)
# 2️⃣ Calculate PA (column-wise) and UA (row-wise)
PA <- diag(conf_prop) / colSums(conf_prop)    # Producer's Accuracy
UA <- diag(conf_prop) / rowSums(conf_prop)    # User's Accuracy
# 3️⃣ Add UA as a new column
conf_df$UA <- UA
# 4️⃣ Add PA as a new row, NA in the corner
PA_row <- c(PA, NA)  # NA for the corner cell
conf_df <- rbind(conf_df, c(Predicted = "PA", as.list(PA_row)))
# 1️⃣ Convert confusion matrix to proportions by reference class
conf_prop <- prop.table(conf_matrix, 2)  # values 0–1
conf_df <- as.data.frame(conf_prop)
# 2️⃣ Calculate Producer's Accuracy (PA, per column) and User's Accuracy (UA, per row)
PA <- diag(conf_prop) / colSums(conf_prop)
UA <- diag(conf_prop) / rowSums(conf_prop)
# 3️⃣ Add UA as a new column (right-most)
conf_df$UA <- round(UA, 2)
# 4️⃣ Prepare PA row with correct number of columns (including corner)
PA_row <- c(round(PA, 2), NA)  # NA in UA corner
PA_row_df <- as.data.frame(t(PA_row))
colnames(PA_row_df) <- colnames(conf_df)
PA_row_df$Predicted <- "PA"     # row label
PA_row_df <- PA_row_df[, colnames(conf_df)]  # ensure same column order
# 5️⃣ Add PA row to conf_df
conf_df <- rbind(conf_df, PA_row_df)
# 6️⃣ Melt for ggplot
conf_long <- melt(conf_df, id.vars = "Predicted")
colnames(conf_long) <- c("Predicted", "Reference", "Proportion")
# 6️⃣ Melt for ggplot
conf_long <- melt(conf_df, id.vars = "Predicted")
# 6️⃣ Melt for ggplot
