# 1️⃣ Convert confusion matrix to proportions by reference class
conf_prop <- prop.table(conf_matrix, 2)  # values 0–1
conf_df <- as.data.frame(conf_prop)
# 2️⃣ Add Predicted as a proper column (row names of original matrix)
conf_df$Predicted <- rownames(conf_df)
# 3️⃣ Calculate Producer's Accuracy (PA, per column) and User's Accuracy (UA, per row)
PA <- diag(conf_prop) / colSums(conf_prop)
UA <- diag(conf_prop) / rowSums(conf_prop)
# 4️⃣ Add UA as a new column
conf_df$UA <- round(UA, 2)
# 5️⃣ Prepare PA row with correct number of columns (including corner)
PA_row <- c(round(PA, 2), NA, "PA")  # last element is Predicted label
PA_row_df <- as.data.frame(t(PA_row), stringsAsFactors = FALSE)
colnames(PA_row_df) <- colnames(conf_df)
# 6️⃣ Bind PA row
conf_df <- rbind(conf_df, PA_row_df)
# 1️⃣ Convert confusion matrix to proportions (0-1)
conf_prop <- prop.table(conf_matrix, 2)
conf_df <- as.data.frame(conf_prop)
# 2️⃣ Add Predicted column from row names
conf_df$Predicted <- rownames(conf_df)
# 3️⃣ Calculate User's Accuracy (UA) and Producer's Accuracy (PA)
UA <- diag(conf_prop) / rowSums(conf_prop)    # row-wise
PA <- diag(conf_prop) / colSums(conf_prop)    # column-wise
# 4️⃣ Add UA as a new column
conf_df$UA <- round(UA, 2)
# 5️⃣ Prepare PA row
PA_row <- c(round(PA, 2), NA, "PA")  # last element = Predicted label
PA_row_df <- as.data.frame(t(PA_row), stringsAsFactors = FALSE)
# 6️⃣ Set column names exactly as conf_df
colnames(PA_row_df) <- colnames(conf_df)
# 7️⃣ Convert numeric columns to numeric (after rbind)
numeric_cols <- setdiff(colnames(conf_df), "Predicted")
PA_row_df[numeric_cols] <- lapply(PA_row_df[numeric_cols], as.numeric)
# 8️⃣ Bind PA row
conf_df <- rbind(conf_df, PA_row_df)
# 1️⃣ Convert confusion matrix to proportions
conf_prop <- prop.table(conf_matrix, 2)
conf_df <- as.data.frame(conf_prop)
# 2️⃣ Add Predicted column from rownames
conf_df$Predicted <- rownames(conf_df)
# 3️⃣ Calculate UA (row-wise) and PA (column-wise)
UA <- diag(conf_prop) / rowSums(conf_prop)
PA <- diag(conf_prop) / colSums(conf_prop)
# 4️⃣ Add UA column to conf_df
conf_df$UA <- round(UA, 2)
# 5️⃣ Prepare PA row
# Convert all numeric columns to character first to avoid rbind type mismatch
numeric_cols <- colnames(conf_df)[colnames(conf_df) != "Predicted"]
conf_df[numeric_cols] <- lapply(conf_df[numeric_cols], as.character)
# Create PA row with same number of columns and same names
PA_row <- c(round(PA, 2), "NA", "PA")          # numeric as character, last element = Predicted
PA_row_df <- as.data.frame(t(PA_row), stringsAsFactors = FALSE)
colnames(PA_row_df) <- colnames(conf_df)       # match column names exactly
# 6️⃣ Bind PA row safely
conf_df <- rbind(conf_df, PA_row_df)
# 7️⃣ Convert numeric columns back to numeric where possible (exclude Predicted)
conf_df[numeric_cols] <- lapply(conf_df[numeric_cols], function(x) as.numeric(as.character(x)))
# 6️⃣ Bind PA row safely
conf_df <- rbind(conf_df, PA_row_df)
View(conf_df)
View(PA_row_df)
