# Extract predictor rasters
zq95_raster <- terra::subset(pixel_metrics_all, "zq95")
#Total DH across AFRF
# Extract predictor rasters
zq95_raster <- terra::subset(pixel_metrics_all, "zq95")
# Function
f_dh <- function(x){
3.55544 + 0.91019*x[1]
}
# Apply
dominant_height_raster <- terra::app(zq95_raster, f_dh)
# Function
f_dh <- function(zq95){
3.55544 + 0.91019 * zq95
}
# Apply
dominant_height_raster <- terra::app(zq95_raster, f_dh)
plot(dominant_height_raster, main="Predicted Dominant Height")
