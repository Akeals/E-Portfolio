library(reshape2)  # for melting the matrix
# Convert confusion matrix to long format
conf_long <- melt(conf_matrix)
colnames(conf_long) <- c("Predicted", "Reference", "Count")
# Plot confusion matrix as a heatmap
ggplot(conf_long, aes(x = Reference, y = Predicted, fill = Count)) +
geom_tile(color = "white") +
geom_text(aes(label = Count), color = "black", size = 5) +
scale_fill_gradient(low = "white", high = "steelblue") +
theme_minimal() +
labs(
title = "Confusion Matrix of Classified Land Cover",
x = "Reference Class",
y = "Predicted Class",
fill = "Number of Pixels"
) +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
# Convert to proportions by reference class
conf_prop <- prop.table(conf_matrix, 2)  # divide by column sums
conf_long <- melt(conf_prop)
colnames(conf_long) <- c("Predicted", "Reference", "Proportion")
